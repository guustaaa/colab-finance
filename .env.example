# === OANDA V20 API ===
# Get from: https://www.oanda.com/demo-account/tpa/personal_token
OANDA_ACCESS_TOKEN=your_v20_personal_access_token_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_ENVIRONMENT=practice

# === Notifications (Discord/Slack Webhook) ===
WEBHOOK_URL=your_discord_or_slack_webhook_url

# === Trading Config ===
# Fraction of Kelly criterion to use (0.25 = quarter Kelly, conservative)
KELLY_FRACTION=0.25
# Maximum percentage of account to risk per trade
MAX_RISK_PCT=0.01
# Maximum drawdown before halting (percentage)
MAX_DRAWDOWN_PCT=0.10
