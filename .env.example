# ─────────────────────────────────────────────
# Capital.com API Credentials
# ─────────────────────────────────────────────
# Generate an API key at: capital.com → Settings → API integrations
# 1. Enable 2FA first
# 2. Click "Generate new key"
# 3. Set a CUSTOM PASSWORD (this is CAPITAL_PASSWORD, NOT your login password)
# 4. Copy the generated API key (shown only once!)

CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your_login_email@example.com
CAPITAL_PASSWORD=your_custom_api_key_password
CAPITAL_DEMO=true

# ─────────────────────────────────────────────
# Optional: Notification Webhook
# ─────────────────────────────────────────────
# Discord or Slack webhook URL for trade notifications
WEBHOOK_URL=
